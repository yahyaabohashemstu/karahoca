# Google Analytics Configuration
# احصل على معرف GA4 من: https://analytics.google.com/
# شكل المعرف: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Frontend API base URL
# اتركه فارغاً إذا كانت الواجهة والـ API على نفس النطاق العام.
# للتطوير المحلي فقط، يمكنك إلغاء تعليق السطر التالي:
# VITE_BACKEND_URL=http://localhost:5000
VITE_BACKEND_URL=

# Backend CORS allowlist
# افصل النطاقات بفواصل. أضف نطاق الواجهة الفعلي في الإنتاج.
# إذا كانت الواجهة والـ API على نفس النطاق، يمكن تركه فارغاً.
ALLOWED_ORIGINS=

# Server-side Gemini API key
# يُستخدم فقط من الخادم المحلي / server/server.mjs
GEMINI_API_KEY=put_server_side_key_here
