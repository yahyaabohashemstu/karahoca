# Google Analytics Configuration
# احصل على معرف GA4 من: https://analytics.google.com/
# شكل المعرف: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Frontend API base URL
# اتركه فارغاً إذا كانت الواجهة والـ API على نفس النطاق العام.
# للتطوير المحلي فقط، يمكنك إلغاء تعليق السطر التالي:
# VITE_BACKEND_URL=http://localhost:5000
VITE_BACKEND_URL=

# Backend CORS allowlist
# افصل النطاقات بفواصل. أضف نطاق الواجهة الفعلي في الإنتاج.
# إذا كانت الواجهة والـ API على نفس النطاق، يمكن تركه فارغاً.
ALLOWED_ORIGINS=

# Server-side Gemini API key
# يُستخدم فقط من الخادم المحلي / server/server.mjs
GEMINI_API_KEY=put_server_side_key_here

# PostgreSQL connection string for admin panel and chat persistence
# Example: postgres://user:password@localhost:5432/karahoca
DATABASE_URL=

# Admin authentication
ADMIN_JWT_SECRET=change_me_to_a_long_random_secret
ADMIN_EMAIL=admin@karahoca.local
ADMIN_PASSWORD=change_me_now

# Optional hardening
MAX_REQUEST_BODY_BYTES=1048576
RATE_LIMIT_WINDOW_MS=60000

# ─── Google Analytics 4 — Data API (for admin dashboard) ─────────────────────
# بدون هذين المتغيرين ستظهر تعليمات الإعداد في صفحة التحليلات
#
# الخطوات:
#   1. Google Cloud Console → IAM & Admin → Service Accounts → أنشئ حساباً جديداً
#   2. نزّل ملف JSON لمفاتيح الحساب
#   3. GA4 Admin → Property Access Management → أضف البريد الإلكتروني للحساب كـ Viewer
#   4. Google Cloud Console → APIs & Services → Library → فعّل "Google Analytics Data API"
#   5. انسخ محتوى ملف JSON كاملاً في السطر أدناه (سطر واحد)
#   6. GA_PROPERTY_ID: الرقم فقط من GA4 Admin → Property Settings (مثال: 123456789)

GA_PROPERTY_ID=
GA_SERVICE_ACCOUNT_JSON=

# ─── Email Campaigns (Resend.com — free: 100/day, 3000/month) ─────────────────
# احصل على مفتاح مجاني من: https://resend.com
# FROM_EMAIL يجب أن يكون من نطاق مؤكّد في Resend
RESEND_API_KEY=
FROM_EMAIL=KARAHOCA <noreply@karahoca.com>
SITE_URL=https://karahoca.com
